{#
  cisco_iosxe/main.j2  —  ENTRYPOINT
  ══════════════════════════════════════════════════════════════════════
  Cisco IOS-XE Access / Distribution Switch Configuration
  NetBox Config Context Template

  VARIABLE SCOPE — IMPORTANT
  ──────────────────────────
  All {%- set -%} statements live directly in this file, BEFORE the
  includes. Variables set inside an included file do NOT propagate back
  to the parent scope or to sibling includes — this is standard Jinja2
  include behaviour. Reading variables from the parent scope IS allowed.

  HOW INCLUDES WORK
  ─────────────────
  {% include 'file.j2' %} renders the target file inline at that exact
  position in the output — identical to pasting the file contents here.
  Included files can READ all variables set here.

  {%- include ... -%}  strips all whitespace before and after the tag.
  Each segment file is therefore responsible for its own leading and
  trailing newlines.

  HOW MACROS WORK (interfaces)
  ────────────────────────────
  Interface rendering uses macros defined in macros/interface_macros.j2.
  08_interfaces.j2 imports them with:
    {% from 'cisco_iosxe/macros/interface_macros.j2' import ... with context %}
  The 'with context' clause passes all variables set so far into the
  macro scope — macros otherwise have an isolated scope.

  TO REUSE A SEGMENT IN ANOTHER TEMPLATE
  ───────────────────────────────────────
  Copy the {%- set -%} block below into the other template's entrypoint,
  then include only the segments you need. Example — router template:
    {%- set vlan_group = device.cf["vlan_group"] -%}
    ... (all set lines) ...
    {%- include 'cisco_iosxe/segments/02_aaa.j2' -%}
    {%- include 'cisco_iosxe/segments/12_snmp.j2' -%}
    {%- include 'cisco_iosxe/segments/15_banner.j2' -%}
    {%- include 'cisco_iosxe/segments/16_lines.j2' -%}
    {%- include 'cisco_iosxe/segments/17_ntp.j2' -%}

  SEGMENT MAP
  ───────────
  01_global_services  service·hostname·VRF·logging
  02_aaa            AAA model, groups, auth, authz, accounting
  03_ip_base        ip global, dhcp snooping, udld, vtp, device-tracking
  04_spanning_tree  STP mode, portfast, errdisable recovery
  05_credentials    enable secret, local user, redundancy, transceiver
  06_vlans          VLAN database loop
  07_qos            QoS class-maps + policy-maps
  08_interfaces     Interface rendering via macros/interface_macros.j2
  09_svi            Vlan1 + management SVI
  10_ip_services    default-gateway, http, tacacs/ssh source
  11_acls           All IP access-lists
  12_snmp           SNMP community, traps, hosts
  13_tacacs_servers TACACS server address/key definitions
  14_control_plane  control-plane CPP policy
  15_banner         MOTD banner (EN/FR)
  16_lines          Console + VTY lines
  17_ntp            NTP auth, source, dynamic server list
  ══════════════════════════════════════════════════════════════════════
#}
{%- set vlan_group = device.cf["vlan_group"] -%}
{%- set vlans = vlan_group.vlans.all() -%}
{%- set mgmt_vlan = vlan_group.vlans.get(name='mgmt') if vlan_group and vlan_group.vlans else None -%}
{%- set mgmt_vid = mgmt_vlan.vid if mgmt_vlan else None -%}
{%- set mgmt_net = device.interfaces.get(name='vlan' ~ mgmt_vid).ip_addresses.get().address -%}
{%- set mgmt_ip = mgmt_net.ip -%}
{%- set mgmt_netmask = mgmt_net.netmask -%}
{%- include 'cisco_iosxe/segments/01_global_services.j2' -%}
{%- include 'cisco_iosxe/segments/02_aaa.j2' -%}
{%- include 'cisco_iosxe/segments/03_ip_base.j2' -%}
{%- include 'cisco_iosxe/segments/04_spanning_tree.j2' -%}
{%- include 'cisco_iosxe/segments/05_credentials.j2' -%}
{%- include 'cisco_iosxe/segments/06_vlans.j2' -%}
{%- include 'cisco_iosxe/segments/07_qos.j2' -%}
{%- include 'cisco_iosxe/segments/08_interfaces.j2' -%}
{%- include 'cisco_iosxe/segments/09_svi.j2' -%}
{%- include 'cisco_iosxe/segments/10_ip_services.j2' -%}
{%- include 'cisco_iosxe/segments/11_acls.j2' -%}
{%- include 'cisco_iosxe/segments/12_snmp.j2' -%}
{%- include 'cisco_iosxe/segments/13_tacacs_servers.j2' -%}
{%- include 'cisco_iosxe/segments/14_control_plane.j2' -%}
{%- include 'cisco_iosxe/segments/15_banner.j2' -%}
{%- include 'cisco_iosxe/segments/16_lines.j2' -%}
{%- include 'cisco_iosxe/segments/17_ntp.j2' -%}

{#
  segments/00_context_vars.j2
  ──────────────────────────────────────────────────────────────────────
  All template-level variable resolution lives here.
  No config output — only {%- set -%} statements.

  Because this file is loaded via {% include %}, all variables set here
  are available in the parent scope (main.j2) and in every subsequent
  {% include %} segment.

  Reuse in other templates:
    {%- include 'segments/00_context_vars.j2' -%}
  Provides: vlan_group, vlans, mgmt_vlan, mgmt_vid,
            mgmt_net, mgmt_ip, mgmt_netmask
#}
{%- set vlan_group = device.cf["vlan_group"] -%}
{%- set vlans = vlan_group.vlans.all() -%}
{%- set mgmt_vlan = vlan_group.vlans.get(name='mgmt') if vlan_group and vlan_group.vlans else None -%}
{%- set mgmt_vid = mgmt_vlan.vid if mgmt_vlan else None -%}
{%- set mgmt_net = device.interfaces.get(name='vlan' ~ mgmt_vid).ip_addresses.get().address -%}
{%- set mgmt_ip = mgmt_net.ip -%}
{%- set mgmt_netmask = mgmt_net.netmask -%}

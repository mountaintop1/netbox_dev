{#
  08_interfaces.j2 — Interface rendering via macros
  ══════════════════════════════════════════════════════════════════════
  Imports typed macros from interface_macros.j2.
  The output of this segment is byte-for-byte identical to the original
  inline code in ios_switch.j2 — safe for config diff.

  WHITESPACE NOTES (why tags are written exactly as they are)
  ────────────────────────────────────────────────────────────
  Macros return:  interface X\n <cmds>\n!   (no leading or trailing \n)
  The \n before each interface block is provided by the CALLER, specifically
  by using Jinja2 tags WITHOUT a trailing dash (%} not -%}) so Jinja2
  keeps the newline that follows the tag in the rendered stream.

  Trunk uplink / GE0/0:
    {%- for int in ... %}     ← %} keeps \n  →  \n + macro output
    {{ macro(int) }}
    {%- endfor -%}

  Main interface loop:
    {%- for int in device_interfaces -%}   ← -%} strips \n after for
      {%- if int.mode == 'access' %}       ← %} keeps \n  →  \n + macro
      {{ macro(int) }}
      {%- elif int.lag %}                  ← %} keeps \n  →  \n + macro
      ...

  Result per interface: \ninterface X\n <cmds>\n!
  Between consecutive interfaces: !\ninterface  (single newline, no blank line)
  This is identical to the original {%- set vlan_ids %} / {%- if %} pattern.
#}
{%- from 'cisco_iosxe/macros/interface_macros.j2' import
    trunk_uplink_vc, trunk_uplink_standalone,
    access_port, lag_member_vc, lag_member_standalone,
    ap_trunk, mgmt_oob, unconfigured_port with context -%}
{%- if device.virtual_chassis %}
  {%- set vcs = device.virtual_chassis.members.all() -%}
  {%- for vc in vcs -%}
    {%- set device_interfaces = vc.interfaces.all() -%}
    {%- for int in device_interfaces.filter(type='lag', mode='tagged') %}
{{ trunk_uplink_vc(int) }}
    {%- endfor -%}
    {%- if device_interfaces.filter(name='GigabitEthernet0/0').exists() %}
{{ mgmt_oob() }}
    {%- endif -%}
    {%- for int in device_interfaces -%}
      {%- if int.mode == 'access' %}
{{ access_port(int) }}
      {%- elif int.lag %}
{{ lag_member_vc(int) }}
      {%- elif int.mode == 'tagged' %}
        {%- set desc = (int.description | default('') | lower) -%}
        {%- if 'lap' in desc or 'wif' in desc or 'ap' in desc or 'rap' in desc %}
{{ ap_trunk(int) }}
        {%- endif %}
      {%- elif not int.mode and int.type != 'lag' and int.type != 'virtual' and not int.lag and int.name != 'GigabitEthernet0/0' %}
{{ unconfigured_port(int) }}
      {%- endif -%}
    {%- endfor %}
  {%- endfor %}
{%- else %}
  {%- set device_interfaces = device.interfaces.all() -%}
  {%- for int in device_interfaces.filter(type='lag', mode='tagged') %}
{{ trunk_uplink_standalone(int) }}
  {%- endfor -%}
  {%- if device_interfaces.filter(name='GigabitEthernet0/0').exists() %}
{{ mgmt_oob() }}
  {%- endif -%}
  {%- for int in device_interfaces -%}
    {%- if int.mode == 'access' %}
{{ access_port(int) }}
    {%- elif int.lag %}
{{ lag_member_standalone(int) }}
    {%- elif int.mode == 'tagged' %}
      {%- set desc = (int.description | default('') | lower) -%}
      {%- if 'lap' in desc or 'wif' in desc or 'ap' in desc or 'rap' in desc %}
{{ ap_trunk(int) }}
      {%- endif -%}
    {%- elif not int.mode and int.type != 'lag' and int.type != 'virtual' and int.name != 'GigabitEthernet0/0' %}
{{ unconfigured_port(int) }}
    {%- endif -%}
  {%- endfor %}
{%- endif %}

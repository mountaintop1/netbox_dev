{#
  segments/10_ip_services.j2 — IP services: gateway, HTTP, TACACS source, SSH
  Depends on: mgmt_vid (from 00_context_vars.j2), device.cf["gateway"]
  Reusable: any IOS-XE switch template with management via TACACS + SSH.
#}
ip default-gateway {{ device.cf.get("gateway") }}
ip forward-protocol nd
no ip http server
ip http authentication local
no ip http secure-server
ip tacacs source-interface Vlan{{ mgmt_vid }}
ip ssh bulk-mode 131072
ip ssh time-out 60
ip ssh source-interface Vlan{{ mgmt_vid }}
!
!
